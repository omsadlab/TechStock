@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="@Roles">
    <Authorized>@ChildContent</Authorized>
    <NotAuthorized>@UnauthorizedContent</NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public string Roles { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? UnauthorizedContent { get; set; }
}
