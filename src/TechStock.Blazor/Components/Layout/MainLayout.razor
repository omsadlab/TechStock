@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="1">
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" @onclick="ToggleDrawer" />
                </MudHidden>
                <MudText Typo="Typo.h6" Class="ml-2">TechStock</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" />
            </MudAppBar>

            @* Desktop sidebar *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2">
                    <MudDrawerHeader>
                        <MudText Typo="Typo.h6">TechStock</MudText>
                    </MudDrawerHeader>
                    <SideNav />
                </MudDrawer>
            </MudHidden>

            @* Mobile drawer *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Temporary" Elevation="2">
                    <MudDrawerHeader>
                        <MudText Typo="Typo.h6">TechStock</MudText>
                    </MudDrawerHeader>
                    <SideNav />
                </MudDrawer>
            </MudHidden>

            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
                    @Body
                </MudContainer>
            </MudMainContent>

            @* Mobile bottom navigation *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <BottomNav />
            </MudHidden>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = false;

    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private TechStock.Blazor.Services.BlazorAuthService AuthSvc { get; set; } = default!;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
