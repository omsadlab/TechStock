@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="1">
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" @onclick="ToggleDrawer" />
                </MudHidden>
                <MudText Typo="Typo.h6" Class="ml-2">TechStock</MudText>
                <MudSpacer />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mr-1">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudText Typo="Typo.body2" Color="Color.Inherit">@context.User.Identity?.Name</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@RoleChipColor(context.User.FindFirst(ClaimTypes.Role)?.Value)">
                            @(context.User.FindFirst(ClaimTypes.Role)?.Value ?? "")
                        </MudChip>
                    </MudHidden>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" />
            </MudAppBar>

            @* Desktop sidebar *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2">
                    <MudDrawerHeader>
                        <MudText Typo="Typo.h6">TechStock</MudText>
                    </MudDrawerHeader>
                    <SideNav />
                </MudDrawer>
            </MudHidden>

            @* Mobile drawer *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Temporary" Elevation="2">
                    <MudDrawerHeader>
                        <MudText Typo="Typo.h6">TechStock</MudText>
                    </MudDrawerHeader>
                    <SideNav />
                </MudDrawer>
            </MudHidden>

            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
                    @Body
                </MudContainer>
            </MudMainContent>

            @* Mobile bottom navigation *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <BottomNav />
            </MudHidden>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = false;

    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private TechStock.Blazor.Services.BlazorAuthService AuthSvc { get; set; } = default!;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private static Color RoleChipColor(string? role) => role switch
    {
        "Admin"   => Color.Error,
        "Manager" => Color.Warning,
        _         => Color.Info
    };
}
