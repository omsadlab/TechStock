@page "/claims"
@attribute [Authorize]
@inject TechStock.Blazor.Services.ApiClient Api
@inject NavigationManager Nav

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Justify="Justify.SpaceBetween">
    <MudText Typo="Typo.h4">Warranty Claims</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick='() => Nav.NavigateTo("/claims/new")'>
        New Claim
    </MudButton>
</MudStack>

<MudPaper Class="pa-3 mb-3" Outlined="true">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudSelect @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem T="string?" Value='(string?)null'>All</MudSelectItem>
                <MudSelectItem T="string?" Value='"Pending"'>Pending</MudSelectItem>
                <MudSelectItem T="string?" Value='"InReview"'>In Review</MudSelectItem>
                <MudSelectItem T="string?" Value='"Resolved"'>Resolved</MudSelectItem>
                <MudSelectItem T="string?" Value='"Rejected"'>Rejected</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudDatePicker Label="From" @bind-Date="_from" DateFormat="yyyy-MM-dd"
                           Clearable="true" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudDatePicker Label="To" @bind-Date="_to" DateFormat="yyyy-MM-dd"
                           Clearable="true" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.FilterAlt"
                       OnClick="LoadAsync">Apply</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_claims.Count == 0)
{
    <MudAlert Severity="Severity.Info">No warranty claims found.</MudAlert>
}
else
{
    <MudTable T="ClaimDto" Items="_claims" Hover="true" Dense="true" OnRowClick="@(args => Nav.NavigateTo($"/claims/{args.Item.Id}"))">
        <HeaderContent>
            <MudTh>Claim #</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>Invoice</MudTh>
            <MudTh>Customer</MudTh>
            <MudTh>Product</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-family:monospace">@context.ClaimNumber</MudText>
            </MudTd>
            <MudTd>@context.ClaimedAt.ToString("dd MMM yyyy")</MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-family:monospace">@context.InvoiceNumber</MudText>
            </MudTd>
            <MudTd>@(context.CustomerName ?? "Walk-in")</MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.ProductName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.BrandName</MudText>
            </MudTd>
            <MudTd>
                @if (context.ClaimType == "SubComponent" && !string.IsNullOrEmpty(context.ComponentName))
                {
                    <MudText Typo="Typo.body2">Sub: @context.ComponentName</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2">Whole Item</MudText>
                }
            </MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
        </RowTemplate>
    </MudTable>

    <MudStack Row="true" Justify="Justify.Center" Class="mt-3">
        <MudPagination Count="_totalPages" Selected="_page" SelectedChanged="OnPageChanged" />
    </MudStack>
}

@code {
    private List<ClaimDto> _claims = [];
    private bool _loading = true;
    private string? _statusFilter;
    private DateTime? _from;
    private DateTime? _to;
    private int _page = 1;
    private int _totalPages = 1;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var qs = $"api/claims?page={_page}&pageSize={PageSize}";
            if (!string.IsNullOrEmpty(_statusFilter)) qs += $"&status={_statusFilter}";
            if (_from.HasValue) qs += $"&from={_from.Value:yyyy-MM-dd}";
            if (_to.HasValue) qs += $"&to={_to.Value:yyyy-MM-dd}";

            var result = await Api.GetAsync<PagedResult<ClaimDto>>(qs);
            _claims = result?.Items ?? [];
            _totalPages = (int)Math.Ceiling((result?.TotalCount ?? 0) / (double)PageSize);
        }
        finally { _loading = false; }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private static Color StatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "InReview" => Color.Info,
        "Resolved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default,
    };

    private class ClaimDto
    {
        public Guid Id { get; set; }
        public string ClaimNumber { get; set; } = string.Empty;
        public DateTime ClaimedAt { get; set; }
        public string InvoiceNumber { get; set; } = string.Empty;
        public string? CustomerName { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public string BrandName { get; set; } = string.Empty;
        public string ClaimType { get; set; } = string.Empty;
        public string? ComponentName { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private class PagedResult<T>
    {
        public List<T> Items { get; set; } = [];
        public int TotalCount { get; set; }
    }
}
