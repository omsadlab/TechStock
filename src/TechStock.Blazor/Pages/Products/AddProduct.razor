@page "/products/add"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject TechStock.Blazor.Services.ApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                   OnClick='() => Nav.NavigateTo("/products")' />
    <MudText Typo="Typo.h5">Add Product</MudText>
</MudStack>

<MudCard Style="max-width:720px;">
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_name" Label="Product Name" Required="true"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_model" Label="Model (optional)"
                              Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_brandId" Label="Brand" Required="true"
                           Variant="Variant.Outlined">
                    @foreach (var b in _brands)
                    {
                        <MudSelectItem T="Guid" Value="b.Id">@b.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="Guid" Value="_productTypeId" Label="Product Type" Required="true"
                           Variant="Variant.Outlined"
                           ValueChanged="@((Guid v) => _ = OnTypeChangedAsync(v))">
                    @foreach (var t in _types)
                    {
                        <MudSelectItem T="Guid" Value="t.Id">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_description" Label="Description (optional)"
                              Variant="Variant.Outlined" Lines="3" />
            </MudItem>
        </MudGrid>

        @if (_configTypes.Count > 0)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-3">Specifications</MudText>
            <MudGrid>
                @foreach (var ct in _configTypes)
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@GetConfigValue(ct.Id)"
                                      ValueChanged="@((string v) => SetConfigValue(ct.Id, v))"
                                      Label="@(ct.Name + (ct.IsRequired ? " *" : ""))"
                                      Required="ct.IsRequired"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                }
            </MudGrid>
        }
    </MudCardContent>
    <MudCardActions Class="pa-4">
        <MudButton OnClick='() => Nav.NavigateTo("/products")'
                   Variant="Variant.Text">Cancel</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save Product
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    private string _name = string.Empty;
    private string? _model;
    private Guid _brandId;
    private Guid _productTypeId;
    private string? _description;
    private List<TypeItem> _types = [];
    private List<BrandItem> _brands = [];
    private List<ConfigTypeItem> _configTypes = [];
    private Dictionary<Guid, string> _configValues = [];
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        var t = Api.GetAsync<List<TypeItem>>("api/product-types");
        var b = Api.GetAsync<List<BrandItem>>("api/brands");
        await Task.WhenAll(t, b);
        _types = t.Result ?? [];
        _brands = b.Result ?? [];
    }

    private async Task OnTypeChangedAsync(Guid typeId)
    {
        _productTypeId = typeId;
        _configValues = [];
        if (typeId == Guid.Empty) { _configTypes = []; return; }
        var result = await Api.GetAsync<List<ConfigTypeItem>>($"api/product-types/{typeId}/config-types");
        _configTypes = result ?? [];
    }

    private string GetConfigValue(Guid configTypeId) =>
        _configValues.TryGetValue(configTypeId, out var v) ? v : string.Empty;

    private void SetConfigValue(Guid configTypeId, string value) =>
        _configValues[configTypeId] = value;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || _brandId == Guid.Empty || _productTypeId == Guid.Empty)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        var missingRequired = _configTypes
            .Where(ct => ct.IsRequired && string.IsNullOrWhiteSpace(GetConfigValue(ct.Id)))
            .Select(ct => ct.Name)
            .ToList();
        if (missingRequired.Count > 0)
        {
            Snackbar.Add($"Required specs missing: {string.Join(", ", missingRequired)}", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var configs = _configValues
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
                .Select(kv => new { ConfigTypeId = kv.Key, Value = kv.Value })
                .ToList();

            var result = await Api.PostAsync<ProductResult>("api/products", new
            {
                Name = _name.Trim(),
                Model = string.IsNullOrWhiteSpace(_model) ? null : _model.Trim(),
                BrandId = _brandId,
                ProductTypeId = _productTypeId,
                Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
                Configs = configs
            });

            Snackbar.Add("Product created successfully.", Severity.Success);
            Nav.NavigateTo($"/products/{result!.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create product: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private record TypeItem(Guid Id, string Name, bool IsActive);
    private record BrandItem(Guid Id, string Name, string? Country, bool IsActive);
    private record ConfigTypeItem(Guid Id, string Name, Guid ProductTypeId, int DisplayOrder, bool IsRequired);
    private class ProductResult { public Guid Id { get; set; } }
}
